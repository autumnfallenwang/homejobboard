# PostgreSQL connection string (consumed from M02 onward)
DATABASE_URL=postgresql://homejobboard:homejobboard@localhost:5432/homejobboard_dev

# HTTP server port (local dev)
API_PORT=3001

# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000

# LLM gateway (cluster llmgw, OpenAI-compatible) — fitness scoring
LLM_GATEWAY_URL=http://llmgw.arch.local

# Auto-poll scheduler
POLL_CRON=*/30 * * * *
SCHEDULER_ENABLED=true

# Logging
LOG_LEVEL=info
