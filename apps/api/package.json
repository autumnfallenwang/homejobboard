{
  "name": "@homejobboard/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:fast": "vitest run --exclude '**/*.integration.test.ts'",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file=.env src/db/seed.ts"
  },
  "dependencies": {
    "@homejobboard/shared": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "drizzle-orm": "^0.45.1",
    "fast-xml-parser": "^4.5.0",
    "hono": "^4.6.14",
    "node-cron": "^4.2.1",
    "openai": "^6.33.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.8",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
