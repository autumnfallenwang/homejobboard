{
  "_doc": "Per-project Claude Code settings. Four hooks ship by default: secret-blocking (Bash + Edit/Write paths), the devkit-task plan-mode override, and auto-format-after-write. The hook scripts live under .claude/hooks/ and run via `bash $CLAUDE_PROJECT_DIR/.claude/hooks/<name>.sh`. enabledPlugins is seeded by /devkit-init from the chosen languages + frontend inference.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/devkit-task-plan-mode.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-env-edits.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/check-secrets.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/format-after-write.sh\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "claude-devkit@claude-devkit-marketplace": true,
    "context7@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "playwright@claude-plugins-official": true
  }
}
